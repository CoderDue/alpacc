params {
  lookback = 1.
  lookahead = 3.
}

string = /"([\x00-\x21\x23-\x5B\x5D-\xFF]|\\")*"/.
num = /-?[0-9]+(.[0-9]+)?([eE][\x2B\x2D]?[0-9]+)?/.
ignore = /\s|\n|\t|\r/.

J -> string | num | "{" FS0 "}" | "[" EL0 "]" | "true" | "false".
EL0 -> | J EL1.
EL1 -> | "," J EL1.
FS0 -> | F FS1.
FS1 -> | "," F FS1.
F -> string ":" J.
